# JanSahayak AI — Environment Variables
# Copy to .env and fill in your values

APP_NAME="JanSahayak AI"
DATABASE_URL="sqlite:///./jansahayak.db"

# ── Groq API Keys (get free at console.groq.com) ─────────────────────────────
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# ── OpenRouter API Keys (get free at openrouter.ai) ──────────────────────────
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=

# ── Google Gemini API Keys (get free at aistudio.google.com) ─────────────────
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ── Twilio (WhatsApp Sandbox) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238871

# ── Bhashini (multilingual voice — bhashini.gov.in) ──────────────────────────
BHASHINI_API_KEY=
